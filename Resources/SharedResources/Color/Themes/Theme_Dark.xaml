<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Mystic_ToDo_MAUI_.Resources.SharedResources.Color.Themes.Theme_Dark">


    <!-- Color Tokens -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource blue500}" />
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource teal200}" />
    <SolidColorBrush x:Key="TertiaryBrush" Color="{StaticResource blue300}" />
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource black500}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource gray300}" />
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource white900}" />
    <SolidColorBrush x:Key="TextHeaderBrush" Color="{StaticResource purple800}" />
    <SolidColorBrush x:Key="TextSubHeaderBrush" Color="{StaticResource purple600}" />
    <SolidColorBrush x:Key="MuteTextBrush" Color="{StaticResource gray400}" />

    <!-- Effects -->
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource purple300}" />
    <SolidColorBrush x:Key="LinkBrush" Color="{StaticResource blue500}" />
    <SolidColorBrush x:Key="LinkHoverBrush" Color="{StaticResource blue700}" />
    <SolidColorBrush x:Key="ShadowBrush" Color="{StaticResource gray200}" />
    <SolidColorBrush x:Key="GlowBrush" Color="{StaticResource purple300}" />

    <!-- Gradients -->
    <!-- 
    <LinearGradientBrush x:Key="PrimaryGradient" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="{StaticResource blue500}" Offset="0.0" />
        <GradientStop Color="{StaticResource blue200}" Offset="1.0" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="SecondaryGradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="{StaticResource purple600}" Offset="0.0" />
        <GradientStop Color="{StaticResource purple300}" Offset="1.0" />
    </LinearGradientBrush>
    <RadialGradientBrush x:Key="GlowGradient" Center="0.5,0.5" Radius="0.5">
        <GradientStop Color="{StaticResource purple300}" Offset="0.0" />
        <GradientStop Color="{StaticResource Transparent}" Offset="1.0" />
    </RadialGradientBrush>
-->


    <!-- States -->
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource red500}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource yellow500}" />
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource blue500}" />
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource green500}" />
    <SolidColorBrush x:Key="DisabledBrush" Color="{StaticResource gray500}" />
    <SolidColorBrush x:Key="SelectedBrush" Color="{StaticResource blue500}" />
    <SolidColorBrush x:Key="UnselectedBrush" Color="{StaticResource gray600}" />

    <!-- Inverted Color -->
    <SolidColorBrush x:Key="InverseTextBrush" Color="{StaticResource black500}" />

    <!-- Control Colors -->
    <SolidColorBrush x:Key="ControlBackgroundBrush" Color="{StaticResource blue300}" />
    <SolidColorBrush x:Key="ControlTextBrush" Color="{StaticResource black500}" />
    <SolidColorBrush x:Key="PlaceholderTextBrush" Color="{StaticResource gray600}" />
    <SolidColorBrush x:Key="DividerBrush" Color="{StaticResource purple600}" />
    <SolidColorBrush x:Key="NavigationBarBrush" Color="{StaticResource purple400}" />
    <SolidColorBrush x:Key="NavigationTextBrush" Color="{StaticResource black400}" />
    <SolidColorBrush x:Key="TabBarBackgroundBrush" Color="{StaticResource gray500}" />
    <SolidColorBrush x:Key="TabBarTextBrush" Color="{StaticResource black400}" />

</ResourceDictionary>