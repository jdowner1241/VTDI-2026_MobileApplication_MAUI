    <!-- Page -->
    <Style TargetType="Page" ApplyToDerivedTypes="True">
        <Setter Property="Padding" Value="0"/>
        <Setter Property="BackgroundColor" Value="{StaticResource BackgroundBrush}" />
    </Style>


    <!-- Shell -->
    <Style TargetType="Shell" ApplyToDerivedTypes="True">
        <Setter Property="Shell.BackgroundColor" Value="{StaticResource NavigationBarBrush}" />
        <Setter Property="Shell.ForegroundColor" Value="{StaticResource NavigationTextBrush}" />
        <Setter Property="Shell.TitleColor" Value="{StaticResource NavigationTextBrush}" />
        <Setter Property="Shell.DisabledColor" Value="{StaticResource DisabledBrush}" />
        <Setter Property="Shell.UnselectedColor" Value="{StaticResource UnselectedBrush}" />
        <Setter Property="Shell.NavBarHasShadow" Value="False" />
        <Setter Property="Shell.TabBarBackgroundColor" Value="{StaticResource TabBarBackgroundBrush}" />
        <Setter Property="Shell.TabBarForegroundColor" Value="{StaticResource SurfaceBrush}" />
        <Setter Property="Shell.TabBarTitleColor" Value="{StaticResource NavigationTextBrush}" />
        <Setter Property="Shell.TabBarUnselectedColor" Value="{StaticResource UnselectedBrush}" />
    </Style>

    <!-- NavigationPage -->
    <Style TargetType="NavigationPage">
        <Setter Property="BarBackgroundColor" Value="{StaticResource NavigationBarBrush}" />
        <Setter Property="BarTextColor" Value="{StaticResource NavigationTextBrush}" />
        <Setter Property="IconColor" Value="{StaticResource NavigationTextBrush}" />
    </Style>

    <!-- TabbedPage -->
    <Style TargetType="TabbedPage">
        <Setter Property="BarBackgroundColor" Value="{StaticResource TabBarBackgroundBrush}" />
        <Setter Property="BarTextColor" Value="{StaticResource TertiaryBrush}" />
        <Setter Property="UnselectedTabColor" Value="{StaticResource UnselectedBrush}" />
        <Setter Property="SelectedTabColor" Value="{StaticResource SelectedBrush}" />
    </Style>

</ResourceDictionary>