<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Mystic_ToDo_MAUI_"
             x:Class="Mystic_ToDo_MAUI_.App">
    <Application.Resources>
        <!-- Default Colors -->
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>

        <!-- Custom Colors and Themes -->
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/SharedResources/Color/BaseColors.xaml" />
                <ResourceDictionary Source="Resources/SharedResources/Color/Themes/Theme_Light.xaml" />
                <ResourceDictionary Source="Resources/SharedResources/Color/Themes/Theme_Dark.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
