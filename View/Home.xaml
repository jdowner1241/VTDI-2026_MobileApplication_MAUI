<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Mystic_ToDo_MAUI_.ViewModel"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:groupvm="clr-namespace:Mystic_ToDo_MAUI_.ViewModel.GroupListVM"
             x:Class="Mystic_ToDo_MAUI_.View.Home"
             Title="{Binding Title}">


    <!-- Define the main layout of the page -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="0.4*" />
            <RowDefinition Height="30" />
            <RowDefinition Height="0.6*" />
        </Grid.RowDefinitions>

        <!-- Folder Area -->
        <HorizontalStackLayout Grid.Column="0" Grid.Row="0" Grid.RowSpan="3">
            <Border x:Name="GroupListDock1" IsVisible="{Binding IsGroupListExpanded}"
                BackgroundColor="{StaticResource Black }" Stroke="{StaticResource App_purple300Brush}" 
                 Padding="10,10" >

                <!-- Folder Entires  -->
                <RefreshView IsRefreshing="{Binding IsLoading}"
                        Command="{Binding GetGroupListCommand}">

                    <CollectionView ItemsSource="{Binding GroupList}"
                        SelectionMode="Single"
                        SelectionChangedCommand="{Binding SelectGroupCommand}"
                        SelectionChangedCommandParameter="{Binding SelectedItem, Source={RelativeSource Self}}"
                        Background="{StaticResource App_black500}">

                        <CollectionView.Header>
                            <Label Text="Folder"
                                FontSize="Subtitle"
                                TextColor="{StaticResource App_cyan500}"
                                FontFamily="VampireWars"
                                HorizontalOptions="Center" 
                                Margin="0,0,0,10"/>
                        </CollectionView.Header>

                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="groupvm:GroupListViewModel">
                                <!-- Each folder row -->

                                <Grid ColumnSpacing="5" RowSpacing="5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Selection indicator -->
                                    <BoxView Grid.Column="0"
                         HeightRequest="20"
                         WidthRequest="10"
                         Color="{Binding SelectionIndicatorColor}" />


                                    <!-- Content -->
                                    <StackLayout Grid.Column="1"
                                        Orientation="Horizontal"
                                        Spacing="10"
                                        Margin="{Binding IndentMargin}"
                                        Background="{StaticResource App_blue500}">

                                        <Image Source="{Binding Icon}"
                                            HeightRequest="20"
                                            Aspect="AspectFit"/>

                                        <Label Text="{Binding GroupName}"
                                            FontSize="Body"
                                            TextColor="{StaticResource App_black900}" />

                                    </StackLayout>

                                </Grid>

                            </DataTemplate>
                        </CollectionView.ItemTemplate>

                        <CollectionView.Footer>
                            <StackLayout Orientation="Horizontal" HorizontalOptions="Center" Spacing="20">
                                <Button Text="Add"
                                    BackgroundColor="{StaticResource App_blue600}"
                                    FontSize="Small"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:HomeViewModel}}, Path=AddGroupCommand}" />
                                <Button Text="Remove"
                                    BackgroundColor="{StaticResource App_blue600}"
                                    FontSize="Small"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:HomeViewModel}}, Path=RemoveGroupCommand}"
                                    CommandParameter="{Binding SelectedGroup}" />
                            </StackLayout>
                        </CollectionView.Footer>
                    </CollectionView>
                </RefreshView>
            </Border >

            <!-- FolderGroupDock Toggle Button -->
            <Button x:Name="Expand" ImageSource="{Binding GroupExpanderIcon}" BackgroundColor="Transparent" Text=""
                      VerticalOptions="Center" HorizontalOptions="Center"
                      HeightRequest="20" WidthRequest="20" CornerRadius="0"
                      Padding="0"
                      Command="{Binding Source={RelativeSource AncestorType={x:Type vm:HomeViewModel}}, Path=ExpanderForGroupCommand}"
                      CommandParameter="" >
            </Button>

        </HorizontalStackLayout>

        <!-- Editor -->
        <Border Grid.Column="1" Grid.Row="0" 
            BackgroundColor="{StaticResource App_black500}" Stroke="{StaticResource App_purple400Brush}" 
             Padding="10,10" Margin="10,0,10,10">

            
                <Grid >
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="0.3*" />
                        <ColumnDefinition Width="0.3*" />
                        <ColumnDefinition Width="0.2*" />
                        <ColumnDefinition Width="0.2*" />
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/> 
                        <RowDefinition Height="*"/> 
                        <RowDefinition Height="*"/> 
                        <RowDefinition Height="*"/> 
                        <RowDefinition Height="*"/> 
                    </Grid.RowDefinitions>


                    <!-- Editor : Title -->
                    <StackLayout Orientation="Horizontal" HorizontalOptions="Center" Spacing="20"
                                 Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="0" >

                        <Entry Placeholder=" Enter Task Title" WidthRequest="400"/>

                        <Button Text="{Binding EditorActionText}" WidthRequest="100"
                                Command="{Binding EditorActionCommand}"/>
                    </StackLayout>

                    <!-- Editor :  Alarm -->

                    <toolkit:Expander  Grid.Column="0" Grid.Row="1">
                        <toolkit:Expander.Header>
                            <Label Text="Alarm"
                               FontAttributes="Bold"
                               FontSize="Medium" />
                        </toolkit:Expander.Header>
                        <VerticalStackLayout>
                            
                            <HorizontalStackLayout Padding="10" Margin="0, 10">
                                <Label Text="Set Alarm"
                                    FontAttributes="Italic" />
                                <DatePicker />
                            </HorizontalStackLayout>
                            
                            <HorizontalStackLayout Padding="10" Margin="0, 10">
                                <Label Text="Repeat Alarm"
                                        FontAttributes="Italic" />
                                <Picker Title="Select an option"
                                    ItemsSource="{Binding TaskList_RepeatTag}"
                                    SelectedItem="{Binding RepeatListTagIndex}" />
                            </HorizontalStackLayout>
                            
                        </VerticalStackLayout>
               
                    </toolkit:Expander>

                    <!-- Editor :  More Info -->
                    <toolkit:Expander Grid.Column="2" Grid.Row="1">
                        <toolkit:Expander.Header>
                            <Label Text="Details"
                                 FontAttributes="Bold"
                                 FontSize="Medium" />
                        </toolkit:Expander.Header>

                        <VerticalStackLayout>

                            <HorizontalStackLayout Padding="10" Margin="0, 10">
                                <Label Text="Notes"
                                        FontAttributes="Italic" />
                                <Editor />
                            </HorizontalStackLayout>

                            <HorizontalStackLayout Padding="10" Margin="0, 10">
                                <Label Text="Attachment"
                                        FontAttributes="Italic" />
                                <ImageButton Source="attach_file.png" Command="{Binding EditorAttachCommand}"/>
                            </HorizontalStackLayout>

                        </VerticalStackLayout>
                    </toolkit:Expander>


                </Grid>
 
        </Border>

     
        <!-- Search Bar-->
        <Border Grid.Column="1" Grid.Row="1" 
           BackgroundColor="{StaticResource App_black500}" Stroke="{StaticResource App_purple400Brush}" 
            Padding="10,10" Margin="10,0,10,0">
            
        <!-- Editor Table -->
        <Border Grid.Column="1" Grid.Row="2"
                BackgroundColor="{StaticResource App_black500}" Stroke="{StaticResource App_purple400Brush}" 
                Padding="10,10" Margin="10,10,10,10">
        </Border>

        </Border>

    </Grid>

   
     
    
</ContentPage>