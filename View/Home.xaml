<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Mystic_ToDo_MAUI_.ViewModel"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:basecolor="clr-namespace:Mystic_ToDo_MAUI_.Resources.SharedResources.SharedColor"
             xmlns:homevms="clr-namespace:Mystic_ToDo_MAUI_.ViewModel.HomeVM"
             
             x:Class="Mystic_ToDo_MAUI_.View.Home"
             Title="{Binding Title}">


    <!-- Define the main layout of the page -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="0.4*" />
            <RowDefinition Height="50" />
            <RowDefinition Height="0.6*" />
        </Grid.RowDefinitions>

        <!-- Folder Area -->
        <HorizontalStackLayout Grid.Column="0" Grid.Row="0" Grid.RowSpan="3">
            <Border x:Name="GroupListDock1" IsVisible="{Binding IsGroupListExpanded}"
                BackgroundColor="{StaticResource Black }" Stroke="{StaticResource App_purple300Brush}" 
                 Padding="10,10" >

                <!-- Folder Entires  -->
                <RefreshView IsRefreshing="{Binding IsLoading}"
                        Command="{Binding GetGroupListCommand}">

                    <CollectionView ItemsSource="{Binding GroupList}"
                                    SelectionMode="Single"
                                    SelectionChangedCommand="{Binding SelectGroupCommand}"
                                    SelectionChangedCommandParameter="{Binding SelectedItem, Source={RelativeSource Self}}"
                                    Background="{StaticResource App_black500}">

                        <CollectionView.Header>
                            <Label Text="Folder"
                                FontSize="Subtitle"
                                TextColor="{StaticResource App_cyan500}"
                                FontFamily="VampireWars"
                                HorizontalOptions="Center" 
                                Margin="0,0,0,10"/>
                        </CollectionView.Header>

                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="homevms:GroupListViewModel">
                                <!-- Each folder row -->

                                <Grid ColumnSpacing="5" RowSpacing="5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Content -->
                                    <StackLayout Grid.Column="1"
                                        Orientation="Horizontal"
                                        Spacing="10"
                                        Margin="{Binding IndentMargin}"
                                        Background="{StaticResource App_blue500}">

                                        <StackLayout.Triggers>
                                            <DataTrigger TargetType="StackLayout" 
                                                         Binding="{Binding IsSelected}" 
                                                         Value="True">
                                                <Setter Property="BackgroundColor" Value="{StaticResource App_blue200}"/>
                                            </DataTrigger>
                                        </StackLayout.Triggers>

                                        <Image Source="{Binding Icon}"
                                            HeightRequest="20"
                                            Aspect="AspectFit"/>

                                        <Label Text="{Binding GroupName}"
                                            FontSize="Body"
                                            TextColor="{StaticResource App_black900}" />

                                    </StackLayout>

                                </Grid>

                            </DataTemplate>
                        </CollectionView.ItemTemplate>

                        <CollectionView.Footer>
                            <StackLayout Orientation="Horizontal" HorizontalOptions="Center" Spacing="20">
                                <Button Text="Add"
                                    BackgroundColor="{StaticResource App_blue600}"
                                    FontSize="Small"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:HomeViewModel}}, Path=AddGroupCommand}" />
                                <Button Text="Remove"
                                    BackgroundColor="{StaticResource App_blue600}"
                                    FontSize="Small"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:HomeViewModel}}, Path=RemoveGroupCommand}"
                                    CommandParameter="{Binding SelectedGroup}" />
                            </StackLayout>
                        </CollectionView.Footer>
                    </CollectionView>
                </RefreshView>
            </Border >

            <!-- FolderGroupDock Toggle Button -->
            <Button x:Name="Expand" ImageSource="{Binding GroupExpanderIcon}" BackgroundColor="Transparent" Text=""
                      VerticalOptions="Center" HorizontalOptions="Center"
                      HeightRequest="20" WidthRequest="20" CornerRadius="0"
                      Padding="0"
                      Command="{Binding Source={RelativeSource AncestorType={x:Type vm:HomeViewModel}}, Path=ExpanderForGroupCommand}"
                      CommandParameter="" >
            </Button>

        </HorizontalStackLayout>

        <!-- Editor -->
        <Border Grid.Column="1" Grid.Row="0" 
            BackgroundColor="{StaticResource App_black500}" Stroke="{StaticResource App_purple400Brush}" 
             Padding="10,10" Margin="10,0,10,10">


            <Grid RowSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.3*" />
                    <ColumnDefinition Width="0.2*" />
                    <ColumnDefinition Width="0.2*" />
                    <ColumnDefinition Width="0.4*" />
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                

                <!-- Editor : Task Title -->
                <StackLayout Orientation="Horizontal" HorizontalOptions="Center" VerticalOptions="Start" 
                                 Spacing="20" Grid.Column="0" Grid.ColumnSpan="4" Grid.Row="0" Margin="0, 10">

                    <Entry Placeholder=" Enter Task Title" WidthRequest="400"
                               Text="{Binding EditorTaskTitle, Mode=TwoWay}"
                               Background="{StaticResource App_gray800Brush}"/>

                    <Button Text="{Binding EditorActionText}" WidthRequest="100"
                                Command="{Binding EditorActionCommand}"/>

                    <Button Text="Clear" WidthRequest="100"
                                Command="{Binding EditorClearCommand}"/>

                    <ImageButton Source="alarm.png" ToolTipProperties.Text="Set Alarm"
                                 Command="{Binding EditorAlarmToggleCommand}"/>
                    <ImageButton Source="event_repeat.png" ToolTipProperties.Text="Repeat Alarm"
                                  Command="{Binding EditorRepeatToggleCommand}"/>
                    <ImageButton Source="attach_file.png" Aspect="AspectFit"
                                     ToolTipProperties.Text="Add Attachment"
                                     Command="{Binding EditorAttachmentAddCommand}"/>
                    <ImageButton Source="delete_red.png" Aspect="AspectFit"
                                    ToolTipProperties.Text="Delete Task"
                                    IsVisible="{Binding EditorAllowDelete}"
                                    Command="{Binding EditorTaskDeleteCommand}"/>

                    <CarouselView >
                        
                    </CarouselView>
                </StackLayout>


                <!-- Editor :  Notes-->
                <StackLayout Orientation="Vertical" VerticalOptions="Start" HorizontalOptions="Center"
                            Grid.Column="0" Grid.Row="1" Spacing="10"
                            Margin="5, 10 ">

                    <Label Text="Notes" ToolTipProperties.Text="Set a Description"
                                    FontAttributes="None" />
                    <Editor WidthRequest="200" HeightRequest="70" Placeholder="Set a Description" 
                                    Text="{Binding EditorNotes, Mode=TwoWay}"
                                    Background="{StaticResource App_gray800Brush}"/>
                </StackLayout>

                <!-- Editor :  Alarm -->
                <StackLayout Orientation="Vertical" VerticalOptions="Start" HorizontalOptions="Start"
                            Grid.Column="1" Grid.Row="1" Spacing="10"
                            Margin="5, 10" 
                            IsVisible="{Binding EditorAlarmIsEnabled}">

                    <Label Text="Alarm" ToolTipProperties.Text="Set a Alarm"
                                    FontAttributes="None" />

                    <DatePicker WidthRequest="220"
                                ToolTipProperties.Text="Set Date"
                                Format="MMMM dd, yyyy"
                                Date="{Binding EditorAlarmDate, Mode=TwoWay}"
                                Background="{StaticResource App_gray800Brush}"
                                HorizontalOptions="Center" 
                                FontAutoScalingEnabled="True"/>

                    <TimePicker WidthRequest="220"
                                ToolTipProperties.Text="Set Time"
                                Time="{Binding EditorAlarmTime, Mode=TwoWay}"
                                Background="{StaticResource App_gray800Brush}"
                                Format="hh:mm tt" 
                                FontAutoScalingEnabled="True"
                                HorizontalOptions="Center"/>

                </StackLayout>

                <!-- Editor :  Alarm Repeat -->
                <StackLayout Orientation="Vertical" VerticalOptions="Start" HorizontalOptions="Center"
                            Grid.Column="2" Grid.Row="1" Spacing="10"
                            Margin="5, 10"
                            IsVisible="{Binding RepeatListTagIsEnabled}">

                    <Label Text="Repeat Alarm" ToolTipProperties.Text="Repeat the Alarm"
                                    FontAttributes="None" />

                    <Picker WidthRequest="150" ToolTipProperties.Text="Repeat the Alarm"
                                Background="{StaticResource App_gray800Brush}"
                                ItemsSource="{Binding RepeatTags}"
                                SelectedItem="{Binding RepeatListTagSelected, Mode=TwoWay}"/>

                </StackLayout>

                <!-- Editor :  Attachments -->
                <Grid VerticalOptions="Start" HorizontalOptions="Center"
                       Grid.Column="3" Grid.Row="1"
                       Margin="5, 10 "
                       RowDefinitions="Auto,*">

                    <Grid Padding="5" ColumnDefinitions="2*,2*"  
                            Background="{StaticResource App_purple800}" Grid.Row="0">

                        <Label Text="Name" FontAttributes="Bold"  
                                TextColor="{StaticResource App_white500}"/>
                        <Label Text="Type" FontAttributes="Bold" Grid.Column="1"  
                                TextColor="{StaticResource App_white500}"/>
                    </Grid>

                    <CollectionView ItemsSource="{Binding EditorAttachmentList}"
                                    ToolTipProperties.Text="Attachments"
                                    VerticalOptions="FillAndExpand"
                                    SelectionMode="Single"
                                    SelectionChangedCommand="{Binding EditorAttachmentSelectCommand}"
                                    SelectionChangedCommandParameter="{Binding SelectedItem, Source={RelativeSource Self}}"
                                    Grid.Row="1">

                        <CollectionView.EmptyView>
                            <Grid Padding="5" ColumnDefinitions="2*,2*">
                                <Label Text="No attachments" 
                                       Grid.ColumnSpan="2"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"
                                       TextColor="{StaticResource App_white500}" />
                            </Grid>
                        </CollectionView.EmptyView>

                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="5" ColumnDefinitions="2*,2*">
                                    <Label Text="{Binding AttachmentName}" />
                                    <Label Text="{Binding AttachmentType}" Grid.Column="1" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Grid>
            </Grid>
        </Border>

     
        <!-- Search Bar-->
        <Border Grid.Column="1" Grid.Row="1" 
           BackgroundColor="{StaticResource App_black500}" Stroke="{StaticResource App_purple400Brush}" 
            Padding="10,5" Margin="10,2">

            <Grid ColumnDefinitions="Auto,*">
                <!-- Left side: Label -->
                <Label Text="{Binding SelectedGroup.GroupName}"  
                       VerticalOptions="Center" 
                       HorizontalOptions="Start"
                       FontAttributes="Bold" FontSize="25" FontFamily="VampireWars"  
                       TextColor="{StaticResource App_purple600}"
                       Margin="30,0"
                       Grid.Column="0"/>

                <!-- Right side: Search + Pickers -->
                <StackLayout Orientation="Horizontal" 
                 VerticalOptions="Center" 
                 HorizontalOptions="End"
                 Spacing="25"
                 Grid.Column="1">
                    
                    <SearchBar Placeholder="Search" ToolTipProperties.Text="Search for a Task" 
                               Text="{Binding EditorSearchQuery}"
                                Background="{StaticResource App_gray800Brush}"
                                WidthRequest="300" />

                    <Picker ToolTipProperties.Text="Sort Type"  
                            Background="{StaticResource App_gray800Brush}"
                            WidthRequest="150" 
                            ItemsSource="{Binding SortTypeList}"
                            SelectedItem="{Binding SortTypeSelected}"/>

                    <Picker ToolTipProperties.Text="Sort Order"  
                            Background="{StaticResource App_gray800Brush}"
                            WidthRequest="150" 
                            ItemsSource="{Binding SortOrderList}"
                            SelectedItem="{Binding SortOrderSelected}"/>
                </StackLayout>
            </Grid>



        </Border>
        
        <!-- Editor Table -->
        <Border Grid.Column="1" Grid.Row="2"
                BackgroundColor="{StaticResource App_black500}" Stroke="{StaticResource App_purple400Brush}" 
                Padding="10,10" Margin="10,10,10,10">

            <CollectionView ItemsSource="{Binding FilteredTaskList}"
                            SelectionMode="Single"
                            SelectionChangedCommand="{Binding TaskSelectionCommand}"
                            SelectionChangedCommandParameter="{Binding SelectedItem, Source={RelativeSource Self}}">

                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="3"/>
                </CollectionView.ItemsLayout>


                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="homevms:TaskListVM">

                        <Border Background="{StaticResource App_gray800}" 
                                Padding="2,5" HeightRequest="60"
                                StrokeShape="RoundRectangle 10">
                            
                            <HorizontalStackLayout VerticalOptions="Center" HorizontalOptions="Start">

                                <CheckBox IsChecked="{Binding IsCompletedDisplay}" 
                                          VerticalOptions="Center" HorizontalOptions="Center" 
                                          Margin="10,0"/>

                                <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Start"
                                                     Spacing="5">

                                    <Label Text="{Binding TaskTitle}" 
                                            HorizontalTextAlignment="Start"/>

                                    <HorizontalStackLayout Spacing="10"
                                                           VerticalOptions="Center" HorizontalOptions="Start">
                                        <Image Source="{Binding AlarmDisplayIcon}" HeightRequest="13" Aspect="AspectFit" />
                                        <Label Text="{Binding AlarmDueDateDisplay}" 
                                               Margin="0,0,10,0" />
                                        <Image Source="{Binding RepeatDisplayIcon}" HeightRequest="13" Aspect="AspectFit" />
                                        <Label Text="{Binding RepeatDisplay}"/>
                                    </HorizontalStackLayout>

                                </VerticalStackLayout>
                            </HorizontalStackLayout>
                        </Border>

                        
                        
                    </DataTemplate>
                </CollectionView.ItemTemplate>

            </CollectionView>

        </Border>

        
    </Grid>
  
    
</ContentPage>