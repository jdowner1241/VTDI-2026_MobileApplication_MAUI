<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Mystic_ToDo_MAUI_.ViewModel"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:groupvm="clr-namespace:Mystic_ToDo_MAUI_.ViewModel.GroupListVM"
             x:Class="Mystic_ToDo_MAUI_.View.Home"
             Title="{Binding Title}">


    <!-- Define the main layout of the page -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="0.4*" />
            <RowDefinition Height="0.6*" />
            <RowDefinition Height="30" />
        </Grid.RowDefinitions>

        <!-- Folder Area -->
        <HorizontalStackLayout Grid.Column="0" Grid.Row="0" Grid.RowSpan="3">
            <Border x:Name="GroupListDock1" IsVisible="{Binding IsGroupListExpanded}"
                BackgroundColor="{StaticResource Black }" Stroke="{StaticResource purple400}" 
                 Padding="10,10" >

                <!-- Folder Entires  -->
                <RefreshView IsRefreshing="{Binding IsLoading}"
                        Command="{Binding GetGroupListCommand}">

                    <CollectionView ItemsSource="{Binding GroupList}"
                        SelectionMode="Single"
                        SelectionChangedCommand="{Binding SelectGroupCommand}"
                        SelectionChangedCommandParameter="{Binding SelectedItem, Source={RelativeSource Self}}"
                        Background="{StaticResource black500}">

                        <CollectionView.Header>
                            <Label Text="Folder"
                                FontSize="Subtitle"
                                TextColor="{StaticResource cyan500}"
                                FontFamily="VampireWars"
                                HorizontalOptions="Center" 
                                Margin="0,0,0,10"/>
                        </CollectionView.Header>

                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="groupvm:GroupListViewModel">
                                <!-- Each folder row -->

                                <Grid ColumnSpacing="5" RowSpacing="5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Selection indicator -->
                                    <BoxView Grid.Column="0"
                         HeightRequest="20"
                         WidthRequest="10"
                         Color="{Binding SelectionIndicatorColor}" />


                                    <!-- Content -->
                                    <StackLayout Grid.Column="1"
                                        Orientation="Horizontal"
                                        Spacing="10"
                                        Margin="{Binding IndentMargin}"
                                        Background="{StaticResource blue500}">

                                        <Image Source="{Binding Icon}"
                                            HeightRequest="20"
                                            Aspect="AspectFit"/>

                                        <Label Text="{Binding GroupName}"
                                            FontSize="Body"
                                            TextColor="{StaticResource black900}" />

                                    </StackLayout>

                                </Grid>

                            </DataTemplate>
                        </CollectionView.ItemTemplate>

                        <CollectionView.Footer>
                            <StackLayout Orientation="Horizontal" HorizontalOptions="Center" Spacing="20">
                                <Button Text="Add"
                                    BackgroundColor="{StaticResource blue600}"
                                    FontSize="Small"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:HomeViewModel}}, Path=AddGroupCommand}" />
                                <Button Text="Remove"
                                    BackgroundColor="{StaticResource blue600}"
                                    FontSize="Small"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:HomeViewModel}}, Path=RemoveGroupCommand}"
                                    CommandParameter="{Binding SelectedGroup}" />
                            </StackLayout>
                        </CollectionView.Footer>
                    </CollectionView>
                </RefreshView>
            </Border >

            <!-- FolderGroupDock Toggle Button -->
            <Button x:Name="Expand" ImageSource="{Binding GroupExpanderIcon}" BackgroundColor="Transparent" Text=""
                      VerticalOptions="Center" HorizontalOptions="Center"
                      HeightRequest="20" WidthRequest="20" CornerRadius="0"
                      Padding="0"
                      Command="{Binding Source={RelativeSource AncestorType={x:Type vm:HomeViewModel}}, Path=ExpanderForGroupCommand}"
                      CommandParameter="" >
            </Button>

        </HorizontalStackLayout>

        <!-- Editor -->
        <Border Grid.Column="1" Grid.Row="0" 
            BackgroundColor="{StaticResource black500}" Stroke="{StaticResource purple400}" 
             Padding="10,10" Margin="10,0,10,10">

            <ScrollView>
                <Grid >
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/> 
                        <RowDefinition Height="*"/> 
                        <RowDefinition Height="*"/> 
                        <RowDefinition Height="*"/> 
                        <RowDefinition Height="*"/> 
                    </Grid.RowDefinitions>


                    <!-- Editor : Title -->
                    <StackLayout Orientation="Horizontal" HorizontalOptions="Center" Spacing="20"
                                 Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="0" >

                        <Entry Placeholder=" Enter Task Title" WidthRequest="400"/>

                        <Button Text="{Binding EditorActionText}" WidthRequest="100"
                                Command="{Binding EditorActionCommand}"/>
                    </StackLayout>

                    <!-- Editor :  Alarm -->

                    <toolkit:Expander  Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="1">
                        <toolkit:Expander.Header>
                            <Label Text="Alarm"
                               FontAttributes="Bold"
                               FontSize="Medium" />
                        </toolkit:Expander.Header>
                        <HorizontalStackLayout Padding="10">
                            <Image Source="http://upload.wikimedia.org/wikipedia/commons/thumb/f/fc/Papio_anubis_%28Serengeti%2C_2009%29.jpg/200px-Papio_anubis_%28Serengeti%2C_2009%29.jpg"
                                   Aspect="AspectFill"
                                   HeightRequest="120"
                                   WidthRequest="120" />
                            <Label Text="Baboons are African and Arabian Old World monkeys belonging to the genus Papio, part of the subfamily Cercopithecinae."
                                    FontAttributes="Italic" />
                        </HorizontalStackLayout>
                    </toolkit:Expander>

                    <!-- Editor :  Description -->
                    <toolkit:Expander Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="2">
                        <toolkit:Expander.Header>
                            <Label Text="Alarm"
                                 FontAttributes="Bold"
                                 FontSize="Medium" />
                        </toolkit:Expander.Header>
                        <HorizontalStackLayout Padding="10">
                            <Image Source="http://upload.wikimedia.org/wikipedia/commons/thumb/f/fc/Papio_anubis_%28Serengeti%2C_2009%29.jpg/200px-Papio_anubis_%28Serengeti%2C_2009%29.jpg"
                                     Aspect="AspectFill"
                                     HeightRequest="120"
                                     WidthRequest="120" />
                            <Label Text="Baboons are African and Arabian Old World monkeys belonging to the genus Papio, part of the subfamily Cercopithecinae."
                                    FontAttributes="Italic" />
                        </HorizontalStackLayout>
                    </toolkit:Expander>


                </Grid>
            </ScrollView>
        </Border>

        <!-- Editor Table -->
        <Border Grid.Column="1" Grid.Row="1" 
           BackgroundColor="{StaticResource black500}" Stroke="{StaticResource purple400}" 
            Padding="10,10" Margin="10,10,10,10">
            
            
        </Border>
        <!-- Footer-->
        <Border Grid.Column="1" Grid.Row="2" 
           BackgroundColor="{StaticResource black500}" Stroke="{StaticResource purple400}" 
            Padding="10,10" Margin="10,0,10,0">


        </Border>

    </Grid>

   
     
    
</ContentPage>